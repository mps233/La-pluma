{
  "name": "maa-webui-server",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "node server.js",
    "start": "node server.js",
    "check": "node scripts/check-syntax.js",
    "build": "npm run check",
    "test": "node scripts/run-tests.js",
    "test:coverage": "node --test --test-concurrency=1 --experimental-test-coverage",
    "verify": "npm run check && npm run test",
    "fetch-materials": "node scripts/fetch-operator-materials.js",
    "fetch-formulas": "node scripts/fetch-material-formulas.js && node scripts/merge-formulas.js",
    "fetch-all-materials": "node scripts/fetch-all-materials.js",
    "fetch-stages": "node scripts/fetch-stage-data.js",
    "fetch-assets": "node scripts/fetch-game-assets.js",
    "fetch-paradox": "node scripts/fetch-paradox-operators.js",
    "fetch-game-data": "npm run fetch-stages && npm run fetch-paradox"
  },
  "dependencies": {
    "@iarna/toml": "^2.2.5",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "form-data": "^4.0.0",
    "node-cron": "^4.2.1",
    "node-fetch": "^3.3.2"
  }
}
